{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "frontend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 5173,
      "cwd": "frontend"
    },
    {
      "name": "fastapi",
      "runtimeExecutable": "py",
      "runtimeArgs": ["-3.12", "-m", "uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8000", "--reload"],
      "port": 8000
    },
    {
      "name": "stripe-backend",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["node", "server.js"],
      "port": 3001
    }
  ]
}
