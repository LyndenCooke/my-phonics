# MyPhonicsBooks — Environment Variables
# Copy this file to .env and fill in your keys

# AI — Text Generation
ANTHROPIC_API_KEY=your_anthropic_api_key_here                # Claude — story generation, phonics validation, questions

# AI — Image Generation
MIDJOURNEY_API_KEY=your_midjourney_api_key_here                # Midjourney — primary illustration engine
OPENAI_API_KEY=your_openai_api_key_here                        # DALL-E 3 — fallback illustrations
GOOGLE_GEMINI_API_KEY=your_gemini_api_key_here                 # Gemini Imagen — alternative illustrations

# Storage
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# Payments
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Email Delivery
RESEND_API_KEY=                        # Resend — transactional email with PDF attachment

# Feature Flags
STORAGE_BACKEND=sqlite                 # sqlite | supabase
IMAGE_ENGINE=dalle                     # dalle | midjourney | gemini
MAX_VALIDATION_RETRIES=3               # Max retries for phonics quality gate
ENABLE_LEVEL_PACKS=true                # Allow purchasing 10-book level packs
ENABLE_FULL_PROGRAMME=false            # Enable when all 60 templates are tested
